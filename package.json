{
  "name": "wwebjs-electron",
  "version": "1.34.7",
  "description": "Library for interacting with the WhatsApp Web API through electron",
  "main": "./index.js",
  "typings": "./index.d.ts",
  "scripts": {
    "test": "mocha tests --recursive --timeout 5000",
    "test-single": "mocha",
    "shell": "node --experimental-repl-await ./shell.js",
    "generate-docs": "npx jsdoc --configure .jsdoc.json --verbose"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndyTargino/wwebjs-electron.git"
  },
  "keywords": [
    "electron",
    "whatsapp",
    "whatsapp-web",
    "api",
    "bot",
    "client",
    "node"
  ],
  "author": "Anderson Targino",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/AndyTargino/wwebjs-electron/issues"
  },
  "homepage": "https://github.com/AndyTargino/wwebjs-electron",
  "dependencies": {
    "fluent-ffmpeg": "2.1.3",
    "mime": "3.0.0",
    "node-fetch": "2.7.0",
    "node-webpmux": "3.2.1",
    "puppeteer": "24.38.0"
  },
  "peerDependencies": {
    "electron": ">=20"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node-fetch": "^2.6.13",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "dotenv": "^16.6.1",
    "jsdoc": "^3.6.4",
    "jsdoc-baseline": "^0.1.5",
    "mocha": "^11.7.5",
    "sinon": "^21.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "archiver": "7.0.1",
    "fs-extra": "11.3.4",
    "unzipper": "0.12.3"
  }
}
